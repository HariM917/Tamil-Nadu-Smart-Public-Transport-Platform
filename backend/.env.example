# 🚌 Backend Environment Configuration
# Copy this file to .env and fill in your values

# 🗄️ Database
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/tn_transport
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# 🔐 JWT
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 🏗️ Application
APP_NAME=TN Smart Transport
ENVIRONMENT=development
DEBUG=True
API_PREFIX=/api
LOG_LEVEL=INFO

# 🌐 CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 📁 File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
